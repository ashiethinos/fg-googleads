# Google Ads Sandbox Simulator
PORT=4789
API_VERSION=v24

# Default sandbox customer account
SANDBOX_CUSTOMER_ID=1234567890
SANDBOX_CUSTOMER_NAME=FeedGraph Sandbox Store
SANDBOX_CURRENCY=INR

# Auth tokens accepted by the sandbox (any non-empty value works)
SANDBOX_DEVELOPER_TOKEN=sandbox-dev-token
SANDBOX_ACCESS_TOKEN=sandbox-access-token

# Data paths
DATA_DIR=./data
DB_PATH=./data/sandbox.db

# Seed configuration
PRODUCT_COUNT=10000
CAMPAIGN_COUNT=120
ASSET_GROUP_COUNT=60
